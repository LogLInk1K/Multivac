---
import { getEntry } from 'astro:content';

interface Moment {
  content: string;
  date: string;
  images?: string[];
  link?: string;
}

interface WatchingItem {
  title: string;
  year: number;
  cover: string;
  comment: string;
  type: string;
  country?: string;
  ratings?: { source: string; score: number }[];
  links?: { source: string; url: string }[];
}

let recentMoments: Moment[] = [];
let watchingItems: WatchingItem[] = [];

try {
  const momentsData = await getEntry('post', 'moments');
  if (momentsData && momentsData.data.moments) {
    recentMoments = momentsData.data.moments
      .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
      .slice(0, 10)
      .map((m: any) => ({
        content: m.content,
        date: m.date,
        images: m.images || [],
        link: m.link || '',
      }));
  }
} catch (error) {
  console.log('Using empty moments data');
}

try {
  const watchingData = await getEntry('post', 'watching');
  if (watchingData && watchingData.data.watching) {
    watchingItems = watchingData.data.watching as WatchingItem[];
  }
} catch (error) {
  console.log('Using empty watching data');
}

const currentYear = new Date().getFullYear();
const endOfYear = new Date(currentYear, 11, 31, 23, 59, 59);
const now = new Date();
const daysLeft = Math.ceil((endOfYear.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));
const yearProgress = Math.floor(((now.getTime() - new Date(currentYear, 0, 1).getTime()) / (endOfYear.getTime() - new Date(currentYear, 0, 1).getTime())) * 100);

const watchingJson = JSON.stringify(watchingItems.map(m => ({
  title: m.title,
  year: m.year,
  cover: m.cover,
  type: m.type,
  ratings: m.ratings
})));
---

{recentMoments.length > 0 && (
  <div id="moments-ticker" data-watching={watchingJson} class="w-full">
    {/* 现代 Bento 布局：优化了断点，引入更自然的网格间距 */}
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-5 gap-3.5 antialiased">
      
      {/* 1. 动态时刻卡片 (占据主要宽度) */}
      <a href="/moments" class="group relative sm:col-span-2 md:col-span-2 xl:col-span-2 flex items-center h-14 px-4 rounded-3xl border border-zinc-200/80 dark:border-zinc-800/80 bg-gradient-to-r from-zinc-50 to-white dark:from-zinc-950 dark:to-zinc-900/50 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_24px_-6px_rgba(0,0,0,0.1)] transition-all duration-300 overflow-hidden">
        
        <div class="absolute inset-0 bento-glow opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        
        {/* 使用 justify-between 让两端对齐，中间自然留出最大空间 */}
        <div class="relative flex items-center w-full justify-between gap-3">
          
          {/* 左侧：头像与状态点 */}
          <div class="relative flex-shrink-0 w-7 h-7 flex items-center justify-center">
            <img src="/img/avatar.webp" alt="" class="w-7 h-7 rounded-full object-cover ring-2 ring-zinc-100 dark:ring-zinc-800" loading="lazy" decoding="async" />
            <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 rounded-full ring-2 ring-white dark:ring-zinc-900"></span>
          </div>

          {/* 中间：文字跑马灯容器。加入 justify-center 实现水平居中 */}
          <div class="flex-1 min-w-0 relative h-5 overflow-hidden flex justify-center">
            {recentMoments.map((moment, i) => (
              <span
                class="moments-item absolute inset-x-0 top-0 h-full flex items-center justify-center text-center text-sm text-zinc-700 dark:text-zinc-300 tracking-wide transition-all duration-500 font-medium"
                data-index={i}
              >
                <span class="truncate max-w-full">{moment.content}</span>
              </span>
            ))}
          </div>

          {/* 右侧：细腻的右滑箭头 */}
          <svg class="w-4 h-4 text-zinc-400 group-hover:text-zinc-800 dark:group-hover:text-zinc-200 transition-all duration-300 transform group-hover:translate-x-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>

{/* 2. 塔罗牌卡片 */}
      <a href="/tarot" class="group flex items-center h-14 px-4 rounded-2xl border border-zinc-200/80 dark:border-zinc-800/80 bg-zinc-50/50 dark:bg-zinc-900/30 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_24px_-6px_rgba(0,0,0,0.1)] transition-all duration-300">
        {/* 用一个极简的卡片层叠/翻转几何构图替代 Emoji */}
        <div class="w-8 h-8 rounded-xl bg-zinc-100 dark:bg-zinc-800/50 flex items-center justify-center flex-shrink-0 border border-zinc-200/50 dark:border-zinc-700/30 relative overflow-hidden">
          <svg class="w-4 h-4 text-zinc-500 dark:text-zinc-400 transition-transform duration-500 group-hover:rotate-12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            {/* 后层卡片 */}
            <rect x="5" y="5" width="10" height="14" rx="1.5" opacity="0.4" stroke-dasharray="2 2" />
            {/* 前层卡片 */}
            <rect x="9" y="5" width="10" height="14" rx="1.5" class="transition-all duration-300 group-hover:translate-x-[1px] group-hover:-translate-y-[1px]" />
            {/* 卡片中心的神秘学几何锚点 */}
            <circle cx="14" cy="12" r="1.5" fill="currentColor" class="animate-pulse" />
          </svg>
        </div>
        
        {/* 文案去戏剧化，改用更现代的中英双语排版形式 */}
        <div class="flex flex-col min-w-0 ml-3">
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-semibold text-zinc-800 dark:text-zinc-200 tracking-wide">cyberTarot()</span>
            <span class="text-[9px] font-mono px-1 py-px bg-zinc-100 dark:bg-zinc-800 text-zinc-400 dark:text-zinc-500 rounded lowercase tracking-tighter scale-90 origin-left">v1.0</span>
          </div>
          <span class="text-[11px] text-zinc-400 dark:text-zinc-500 mt-0.5 tracking-tight">趣味塔罗，任意抽取</span>
        </div>

        <svg class="w-3.5 h-3.5 text-zinc-300 dark:text-zinc-700 group-hover:text-zinc-500 ml-auto transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      {/* 3. 年进度卡片 */}
      <a href="/progress" class="group flex items-center h-14 px-4 rounded-3xl border border-zinc-200/80 dark:border-zinc-800/80 bg-zinc-50/50 dark:bg-zinc-900/30 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_24px_-6px_rgba(0,0,0,0.1)] transition-all duration-300">
        <div class="flex-shrink-0 relative w-8 h-8">
          <svg class="w-8 h-8 -rotate-90" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" class="text-zinc-200 dark:text-zinc-800"></circle>
            <circle cx="18" cy="18" r="15.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray={`${yearProgress * 0.974} 97.4`} stroke-linecap="round" class="text-zinc-800 dark:text-zinc-200 transition-all duration-1000"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-[9px] font-bold font-mono text-zinc-800 dark:text-zinc-200">{yearProgress}%</span>
          </div>
        </div>
        <div class="flex flex-col min-w-0 ml-3">
          <span class="text-xs font-semibold text-zinc-800 dark:text-zinc-200 tracking-wide">{currentYear} 进程</span>
          <span class="text-[11px] text-zinc-400 dark:text-zinc-500 mt-0.5">今年还剩 <span class="font-bold text-zinc-700 dark:text-zinc-300">{daysLeft}</span> 天</span>
        </div>
        <svg class="w-3.5 h-3.5 text-zinc-300 dark:text-zinc-700 group-hover:text-zinc-500 ml-auto transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      {/* 4. 随机电影推荐卡片 */}
      <a id="movie-recommend-link" href="/time-machine" class="group flex items-center h-14 px-4 rounded-3xl border border-zinc-200/80 dark:border-zinc-800/80 bg-zinc-50/50 dark:bg-zinc-900/30 shadow-[0_2px_8px_-3px_rgba(0,0,0,0.05)] hover:shadow-[0_8px_24px_-6px_rgba(0,0,0,0.1)] transition-all duration-300">
        <div class="w-8 h-8 rounded-lg overflow-hidden flex-shrink-0 bg-zinc-200 dark:bg-zinc-800 shadow-sm" id="movie-cover-wrapper">
          <img id="movie-cover" src="" alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" decoding="async" />
        </div>
        <div class="flex-1 min-w-0 ml-3">
          <span id="movie-recommend-text" class="text-xs font-semibold text-zinc-800 dark:text-zinc-200 truncate block tracking-wide">推荐中...</span>
          <span id="movie-recommend-meta" class="text-[11px] text-zinc-400 dark:text-zinc-500 truncate block mt-0.5"></span>
        </div>
        <svg class="w-3.5 h-3.5 text-zinc-300 dark:text-zinc-700 group-hover:text-zinc-500 flex-shrink-0 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

    </div>
  </div>
)}

<script>
  function initMomentsTicker() {
    const container = document.getElementById('moments-ticker');
    if (!container) return;

    const items = container.querySelectorAll('.moments-item');
    if (items.length === 0) return;

    // 采用更平滑的 cubic-bezier 缓动函数
    const EASE = 'cubic-bezier(0.25, 1, 0.5, 1)';

    items.forEach((item, i) => {
      const el = item as HTMLElement;
      el.style.transition = `all 0.6s ${EASE}`;
      if (i === 0) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      } else {
        el.style.opacity = '0';
        el.style.transform = 'translateY(16px)';
      }
    });

    let currentIndex = 0;

    const timer = setInterval(() => {
      const prevIndex = currentIndex;
      currentIndex = (currentIndex + 1) % items.length;

      const prev = items[prevIndex] as HTMLElement;
      const next = items[currentIndex] as HTMLElement;

      if (prev) {
        prev.style.opacity = '0';
        prev.style.transform = 'translateY(-16px)';
      }
      if (next) {
        next.style.opacity = '1';
        next.style.transform = 'translateY(0)';
      }

      setTimeout(() => {
        if (prev) {
          prev.style.transition = 'none';
          prev.style.transform = 'translateY(16px)';
          void prev.offsetHeight; // 触发回流
          prev.style.transition = `all 0.6s ${EASE}`;
        }
      }, 600);
    }, 4000); // 略微延长停留时间，提高可读性

    (container as any).__momentsTimer = timer;

    // 电影数据注入逻辑保持不变
    const watchingRaw = container.getAttribute('data-watching');
    if (watchingRaw) {
      try {
        const watchingItems = JSON.parse(watchingRaw);
        if (watchingItems && watchingItems.length > 0) {
          const idx = Math.floor(Math.random() * watchingItems.length);
          const movie = watchingItems[idx];
          const movieEl = document.getElementById('movie-recommend-text');
          const movieMetaEl = document.getElementById('movie-recommend-meta');
          const movieCoverEl = document.getElementById('movie-cover') as HTMLImageElement;
          const movieLink = document.getElementById('movie-recommend-link') as HTMLAnchorElement;
          if (movieEl && movie) movieEl.textContent = movie.title;
          if (movieMetaEl && movie) {
            const parts: string[] = [];
            if (movie.type) parts.push(movie.type);
            if (movie.year) parts.push(String(movie.year));
            if (movie.ratings && movie.ratings.length > 0) parts.push(`★ ${movie.ratings[0].score.toFixed(1)}`);
            movieMetaEl.textContent = parts.join(' · ');
          }
          if (movieCoverEl && movie && movie.cover) {
            movieCoverEl.src = movie.cover;
            movieCoverEl.alt = movie.title;
          }
          if (movieLink) movieLink.href = `/time-machine?idx=${idx}`;
        }
      } catch (e) {}
    }
  }

  function cleanupMomentsTicker() {
    const container = document.getElementById('moments-ticker');
    if (container && (container as any).__momentsTimer) {
      clearInterval((container as any).__momentsTimer);
      (container as any).__momentsTimer = null;
    }
  }

  document.addEventListener('astro:page-load', () => {
    cleanupMomentsTicker();
    initMomentsTicker();
  });

  document.addEventListener('astro:after-swap', () => {
    cleanupMomentsTicker();
    initMomentsTicker();
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMomentsTicker);
  } else {
    initMomentsTicker();
  }
</script>

<style is:global>
  /* 现代 Bento 微光互动效果 */
  .bento-glow {
    background: radial-gradient(
      800px circle at var(--x, 20px) var(--y, 20px),
      rgba(244, 244, 245, 0.6),
      transparent 40%
    );
  }
  .dark .bento-glow {
    background: radial-gradient(
      600px circle at 30% 50%,
      rgba(255, 255, 255, 0.03),
      transparent 50%
    );
  }
</style>