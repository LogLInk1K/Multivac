---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { calculateReadingTime } from '../utils/readingTime';
import FormattedDate from './FormattedDate.astro';

const allPosts = await getCollection('post', ({ data }) => !data.draft && !data.friends && !data.friendGroups && !data.moments);
const defaultCover = '/img/df-cover.webp';

interface Props {
  currentPostId: string;
}

const { currentPostId } = Astro.props;

const otherPosts = allPosts.filter(post => post.id !== currentPostId);
const recentPosts = otherPosts.sort((a, b) => {
  const dateA = new Date(a.data.pubDate).getTime();
  const dateB = new Date(b.data.pubDate).getTime();
  return dateB - dateA;
}).slice(0, 2);

const allPostUrls = otherPosts.map(post => `/p/${post.id.toLowerCase()}`);
---

<div class="mt-6 space-y-4">
  <div class="relative mb-4">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <path d="M19 21l-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
        </svg>
        <span class="text-base font-bold text-text-light dark:text-text-dark opacity-80">最近文章推荐</span>
      </div>
      <button 
        id="random-walk-btn"
        class="flex items-center gap-1 px-2 py-1 text-xs text-gray-400 dark:text-gray-500 bg-gray-100/80 dark:bg-gray-800/80 rounded-full cursor-pointer hover:bg-gray-200/80 dark:hover:bg-gray-700/80 transition-colors"
        data-urls={JSON.stringify(allPostUrls)}
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 8h.01"></path>
          <path d="M8 8h.01"></path>
          <path d="M8 16h.01"></path>
          <path d="M16 16h.01"></path>
          <path d="M12 12h.01"></path>
        </svg>
        随便逛逛
      </button>
    </div>
  </div>

  {recentPosts.map((post) => {
    const { title, pubDate, heroImage, category } = post.data;
    const originalFileName = post.id.toLowerCase();
    const displayImage = heroImage || defaultCover;
    const readingTime = calculateReadingTime(post.body || '');

    return (
      <a 
        href={`/p/${originalFileName}`}
        class="group flex items-center gap-4 p-6 bg-gray-50/50 dark:bg-gray-900/50 border border-gray-200/50 dark:border-gray-700/50 rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1"
      >
        <div class="flex-1 min-w-0 flex flex-col justify-between h-28">
          <h3 class="text-2xl font-bold line-clamp-2 text-text-light dark:text-text-dark group-hover:text-primary-light dark:group-hover:text-primary-dark transition-colors">
            {title}
          </h3>

          <div class="flex items-center gap-3">
            <span class="flex items-center gap-1.5 text-xs text-text-light dark:text-text-dark opacity-60">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <FormattedDate date={pubDate} />
            </span>
            {category && (
              <span class="flex items-center gap-1.5 text-xs text-text-light dark:text-text-dark opacity-60">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
                {category}
              </span>
            )}
            <span class="flex items-center gap-1.5 text-xs text-text-light dark:text-text-dark opacity-60">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
              {readingTime} 分钟
            </span>
          </div>
        </div>

        <div class="relative w-36 h-28 flex-shrink-0 overflow-hidden rounded-xl">
          <div
            class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
            style={`background-image: url('${displayImage}');`}
            aria-label={title}
          ></div>
        </div>
      </a>
    );
  })}
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('random-walk-btn');
    if (btn) {
      btn.addEventListener('click', () => {
        const urls = JSON.parse(btn.dataset.urls || '[]');
        if (urls.length > 0) {
          const randomIndex = Math.floor(Math.random() * urls.length);
          window.location.href = urls[randomIndex];
        }
      });
    }
  });
</script>
